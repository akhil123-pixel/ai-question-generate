# GEMINI_API_KEY: Automatically provided by the platform.
# No manual configuration needed for standard models.
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here


# Port for the server
PORT=3000

# Database: Using SQLite (better-sqlite3) by default.
# No MONGO_URI required.
